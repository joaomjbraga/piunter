{
  "name": "@bforgeio/piunter",
  "version": "1.0.0",
  "description": "CLI para limpeza e otimização de sistemas Linux",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "piunter": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint src/**/*.ts",
    "test": "vitest",
    "prepare": "npm run build"
  },
  "keywords": [
    "linux",
    "cleanup",
    "cleaner",
    "optimization",
    "cli",
    "devops"
  ],
  "author": "João Braga",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joaomjbraga/piunter"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-spinners": "^2.9.2",
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "ora": "^7.0.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vitest": "^1.2.0"
  }
}
