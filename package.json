{
  "name": "@bforgeio/piunter",
  "version": "1.2.2",
  "description": "CLI para limpeza e otimização de sistemas Linux",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "piunter": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build && npx husky install",
    "prepack": "npm run build",
    "publish": "npm publish --access public"
  },
  "keywords": [
    "linux",
    "cleanup",
    "cleaner",
    "optimization",
    "cli",
    "devops"
  ],
  "author": "João Braga",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaomjbraga/piunter.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-spinners": "^2.9.2",
    "inquirer": "^9.2.12",
    "ora": "^7.0.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^8.56.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
